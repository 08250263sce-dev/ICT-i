students_list = [] # List to store student names
students_dict = {} # Dictionary to store student details

# Requesting input from the user to add name, age, and grade
name = input("Enter student name: ") 
age = int(input("Enter student age: ")) 
grade = int(input("Enter student grade: ")) 

# Add name to list
students_list.append(name)

# Add details to dictionary
students_dict[name] = {"Age":age, "Grade": grade} #key= name,value= age and grade

# Print success message
print(f"student{name} added successfully!")

# print current data
print("student list:",students_list)
print("student details:",students_dict)

# Function to search for a student
search_name = input("Enter the name of the student to search:")

# check if student exist in the dictionary
if search_name in students_dict:
    print(f"Found:{search_name},Age:{students_dict[search_name]['age']},Grade:{students_dict[search_name]['grade']}")
else:
    print("student not found.")

# Function to remove a student
remove_name = input("Enter the name of the student to remove:")
if remove_name in students_dict:
    # remove from list
    students_list.remove(remove_name)
    # remove from dictionary
    del students_dict[remove_name]
    print(f"student{remove_name}removed successfully!")
else:
    print("student not found.")

# Display revised data
print("Revised students:",students_list)
print("Revised student Details:",students_dict)

